# Copy this file to .env and fill in the values.
#
# Required — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed to download private HuggingFace models
# HF_TOKEN=hf_...

# Optional — set to 1 to block all HuggingFace network calls (fully offline)
# HF_HUB_OFFLINE=0
